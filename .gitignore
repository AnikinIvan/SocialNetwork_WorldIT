# ==============================================================================
# .gitignore: Полный шаблон
# ==============================================================================

# --- ОС / Файловая система (Windows, macOS, Linux) ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.tmp
*.bak
*.swp
*~

# --- IDE и Редакторы ---
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# JetBrains (WebStorm, PyCharm, IDEA, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# --- Зависимости / Пакеты ---
node_modules/
jspm_packages/
bower_components/
vendor/
.pnpm-debug.log*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
ENV/
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# --- JavaScript / TypeScript / Frontend ---
dist/
build/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- PHP / Composer ---
composer.lock
vendor/
.phpintel/

# --- Логи и базы данных ---
*.log
*.sqlite
*.db

# --- Окружение и секреты (ВНИМАНИЕ: Очень важно!) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
secret.json

# --- Docker ---
.docker-ignore
docker-compose.override.yml

# --- Прочее ---
.terraform/
.vagrant/
